<Window x:Class="HangmanGameWPF.GameListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HangmanGameWPF.Localization"
        Title="HANGMAN - PARTIDAS"
        Height="540" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0C0C0C">
    <Grid>
        <Border BorderBrush="#00FF41" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0" Background="#001A00" BorderBrush="#00FF41" BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="{loc:Loc GAMELIST_TITLE_BAR}"
                                   FontFamily="Courier New" FontSize="11" Foreground="#00AA30"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Margin="0,0,6,0">
                            <Button Content="[-]" Style="{StaticResource ChromeButton}" Click="BtnMinimize_Click"/>
                            <Button Content="[X]" Style="{StaticResource ChromeButton}"
                                    Foreground="#FF6666" Margin="4,0,0,0" Click="BtnClose_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Section header -->
                <StackPanel Grid.Row="1" Margin="20,16,20,12">
                    <TextBlock Text="{loc:Loc GAMELIST_TITLE}"
                               FontFamily="Courier New" FontSize="18" FontWeight="Bold"
                               Foreground="#00FF41"/>
                    <Border Background="#00FF41" Height="1" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- DataGrid -->
                <DataGrid x:Name="GameGrid" Grid.Row="2" Margin="20,0,20,0"
                          Background="#0C0C0C" Foreground="#00FF41"
                          BorderBrush="#007A1F" BorderThickness="1"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2A1A"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          RowBackground="#0C0C0C" AlternatingRowBackground="#0A150A"
                          HeadersVisibility="Column" FontFamily="Courier New" FontSize="13">
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#003B10"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#002A0C"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#00FF41"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#00FF41"/>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#001A00"/>
                            <Setter Property="Foreground" Value="#00AA30"/>
                            <Setter Property="BorderBrush" Value="#007A1F"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="FontFamily" Value="Courier New"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="12,8"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="#00FF41"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#001A08"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,7"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{loc:Loc GRID_CREATOR}" Binding="{Binding Nombre}" Width="*"/>
                        <DataGridTextColumn Header="{loc:Loc GRID_EMAIL}" Binding="{Binding Correo}" Width="*"/>
                        <DataGridTextColumn Header="{loc:Loc GRID_CATEGORY}" Binding="{Binding Categoria}" Width="120"/>
                        <DataGridTextColumn Header="{loc:Loc GRID_LANGUAGE}" Binding="{Binding Idioma}" Width="90"/>
                        <DataGridTextColumn Header="{loc:Loc GRID_DESCRIPTION}" Binding="{Binding Descripcion}" Width="*"/>
                        <DataGridTextColumn Header="{loc:Loc GRID_LETTERS}" Binding="{Binding Letras}" Width="70"/>
                        <DataGridTextColumn Header="{loc:Loc GRID_DATE}" Binding="{Binding Fecha}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Bottom buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="20,14,20,14"
                            HorizontalAlignment="Right">
                    <Button Content="{loc:Loc BACK_BUTTON}"
                            Style="{StaticResource RetroButton}"
                            Height="36" Padding="16,0" Margin="0,0,10,0"
                            Click="BtnBack_Click"/>
                    <Button Content="{loc:Loc NEW_GAME_BUTTON}"
                            Style="{StaticResource RetroButton}"
                            Height="36" Padding="16,0" Margin="0,0,10,0"
                            Click="BtnNewGame_Click"/>
                    <Button Content="{loc:Loc PLAY_SELECTED_BUTTON}"
                            Style="{StaticResource RetroButton}"
                            Height="36" Padding="16,0"
                            Click="BtnPlay_Click"/>
                </StackPanel>

                <!-- Footer -->
                <Border Grid.Row="4" Background="#001200" BorderBrush="#00FF41" BorderThickness="0,1,0,0">
                    <TextBlock Text="{loc:Loc FOOTER_SELECT_GAME}"
                               FontFamily="Courier New" FontSize="10" Foreground="#007A1F"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Rectangle IsHitTestVisible="False" Panel.ZIndex="100">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile" Viewport="0,0,1,4" ViewportUnits="Absolute"
                              Viewbox="0,0,1,4" ViewboxUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="#18000000">
                            <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,1,2"/></GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Window>

