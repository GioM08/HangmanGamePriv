<Window x:Class="HangmanGameWPF.EditProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HANGMAN - EDITAR PERFIL"
        Height="560" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0C0C0C">
    <Grid>
        <Border BorderBrush="#00FF41" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0" Background="#001A00" BorderBrush="#00FF41" BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="[ HANGMAN TERMINAL  v1.0 ]  --  EDITAR PERFIL"
                                   FontFamily="Courier New" FontSize="11" Foreground="#00AA30"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Button Content="[X]" Style="{StaticResource ChromeButton}"
                                Foreground="#FF6666" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,6,0"
                                Click="BtnClose_Click"/>
                    </Grid>
                </Border>

                <!-- Form -->
                <StackPanel Grid.Row="1" Margin="36,20,36,0">
                    <TextBlock Text="&gt; EDITAR INFORMACION"
                               FontFamily="Courier New" FontSize="18" FontWeight="Bold"
                               Foreground="#00FF41" Margin="0,0,0,6"/>
                    <Border Background="#00FF41" Height="1" Margin="0,0,0,22"/>

                    <!-- Full Name -->
                    <TextBlock Text="NOMBRE COMPLETO:" FontFamily="Courier New"
                               FontSize="12" Foreground="#00AA30" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtUsername" Height="40"
                             Style="{StaticResource RetroTextBox}" Margin="0,0,0,14"/>

                    <!-- BirthDate -->
                    <TextBlock Text="FECHA DE NACIMIENTO:" FontFamily="Courier New"
                               FontSize="12" Foreground="#00AA30" Margin="0,0,0,4"/>
                    <DatePicker x:Name="DpBirthDate" Height="40" Margin="0,0,0,14"
                                Background="#0A150A" Foreground="#00FF41"
                                BorderBrush="#00AA30" FontFamily="Courier New" FontSize="13"/>

                    <!-- Phone -->
                    <TextBlock Text="TELEFONO:" FontFamily="Courier New"
                               FontSize="12" Foreground="#00AA30" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtPhone" Height="40"
                             Style="{StaticResource RetroTextBox}" Margin="0,0,0,14"/>

                    <!-- Email (read-only) -->
                    <TextBlock Text="CORREO ELECTRONICO  (no editable):"
                               FontFamily="Courier New" FontSize="12"
                               Foreground="#005A00" Margin="0,0,0,4"/>
                    <Border BorderBrush="#005A00" BorderThickness="1" Height="40"
                            Background="#070D07" Margin="0,0,0,14">
                        <TextBlock x:Name="TxtEmail"
                                   FontFamily="Courier New" FontSize="14"
                                   Foreground="#005A00" VerticalAlignment="Center"
                                   Margin="8,0"/>
                    </Border>

                    <TextBlock x:Name="TxtMessage" Text=""
                               FontFamily="Courier New" FontSize="11"
                               Foreground="#FF4444" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="[ CANCELAR ]"
                                Style="{StaticResource RetroButton}" Height="40"
                                Click="BtnCancel_Click"/>
                        <Button Grid.Column="2" Content="[ GUARDAR CAMBIOS ]"
                                Style="{StaticResource RetroButton}" Height="40"
                                Click="BtnSave_Click"/>
                    </Grid>
                </StackPanel>

                <!-- Footer -->
                <Border Grid.Row="2" Background="#001200" BorderBrush="#00FF41" BorderThickness="0,1,0,0">
                    <TextBlock Text="(C) 2024 HANGMAN CORP  |  EL CORREO NO PUEDE MODIFICARSE"
                               FontFamily="Courier New" FontSize="10" Foreground="#007A1F"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Rectangle IsHitTestVisible="False" Panel.ZIndex="100">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile" Viewport="0,0,1,4" ViewportUnits="Absolute"
                              Viewbox="0,0,1,4" ViewboxUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="#18000000">
                            <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,1,2"/></GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Window>
