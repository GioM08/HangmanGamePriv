<Window x:Class="HangmanGameWPF.CreateGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HANGMAN - NUEVA PARTIDA"
        Height="540" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0C0C0C">
    <Grid>
        <Border BorderBrush="#00FF41" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0" Background="#001A00" BorderBrush="#00FF41" BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="[ HANGMAN TERMINAL  v1.0 ]  --  NUEVA PARTIDA"
                                   FontFamily="Courier New" FontSize="11" Foreground="#00AA30"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Button Content="[X]" Style="{StaticResource ChromeButton}"
                                Foreground="#FF6666" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,6,0"
                                Click="BtnClose_Click"/>
                    </Grid>
                </Border>

                <!-- Form -->
                <StackPanel Grid.Row="1" Margin="36,20,36,0">
                    <TextBlock Text="&gt; GENERAR NUEVA PARTIDA"
                               FontFamily="Courier New" FontSize="18" FontWeight="Bold"
                               Foreground="#00FF41" Margin="0,0,0,6"/>
                    <Border Background="#00FF41" Height="1" Margin="0,0,0,20"/>

                    <TextBlock Text="CATEGORIA:" FontFamily="Courier New"
                               FontSize="12" Foreground="#00AA30" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CbCategory" Height="40" Margin="0,0,0,16"
                              Background="#0A150A" Foreground="#00FF41"
                              BorderBrush="#00AA30" FontFamily="Courier New" FontSize="13"
                              SelectionChanged="CbCategory_SelectionChanged">
                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#0A150A"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#003B10"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#00FF41"/>
                        </ComboBox.Resources>
                    </ComboBox>

                    <TextBlock Text="PALABRA:" FontFamily="Courier New"
                               FontSize="12" Foreground="#00AA30" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CbWord" Height="40" Margin="0,0,0,16"
                              Background="#0A150A" Foreground="#00FF41"
                              BorderBrush="#00AA30" FontFamily="Courier New" FontSize="13"
                              DisplayMemberPath="Text">
                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#0A150A"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#003B10"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#00FF41"/>
                        </ComboBox.Resources>
                    </ComboBox>

                    <TextBlock x:Name="TxtHint" Text=""
                               FontFamily="Courier New" FontSize="11"
                               Foreground="#007A1F" Margin="0,0,0,16"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="DESCRIPCION (opcional):" FontFamily="Courier New"
                               FontSize="12" Foreground="#00AA30" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtDescription" Height="40"
                             Style="{StaticResource RetroTextBox}" Margin="0,0,0,20"/>

                    <TextBlock x:Name="TxtError" Text=""
                               FontFamily="Courier New" FontSize="11"
                               Foreground="#FF4444" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="[ CANCELAR ]"
                                Style="{StaticResource RetroButton}" Height="40"
                                Click="BtnCancel_Click"/>
                        <Button Grid.Column="2" Content="[ CREAR PARTIDA ]"
                                Style="{StaticResource RetroButton}" Height="40"
                                Click="BtnCreate_Click"/>
                    </Grid>
                </StackPanel>

                <!-- Footer -->
                <Border Grid.Row="2" Background="#001200" BorderBrush="#00FF41" BorderThickness="0,1,0,0">
                    <TextBlock Text="(C) 2024 HANGMAN CORP  |  CREAR NUEVA PARTIDA"
                               FontFamily="Courier New" FontSize="10" Foreground="#007A1F"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Rectangle IsHitTestVisible="False" Panel.ZIndex="100">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile" Viewport="0,0,1,4" ViewportUnits="Absolute"
                              Viewbox="0,0,1,4" ViewboxUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="#18000000">
                            <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,1,2"/></GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Window>
