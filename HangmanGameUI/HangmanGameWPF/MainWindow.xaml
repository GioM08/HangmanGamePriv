<Window x:Class="HangmanGameWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HangmanGameWPF.Localization"
        Title="HANGMAN GAME"
        Height="620" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0C0C0C">
    <Grid>
        <Border BorderBrush="#00FF41" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0" Background="#001A00"
                        BorderBrush="#00FF41" BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock x:Name="TxtTitleBar"
                                   FontFamily="Courier New" FontSize="11"
                                   Foreground="#00AA30"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Margin="0,0,6,0">
                            <Button Content="[-]" Style="{StaticResource ChromeButton}" Click="BtnMinimize_Click"/>
                            <Button Content="[X]" Style="{StaticResource ChromeButton}"
                                    Foreground="#FF6666" Margin="4,0,0,0" Click="BtnClose_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Welcome header -->
                <StackPanel Grid.Row="1" Margin="28,18,28,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="TxtWelcome"
                                   Grid.Column="0"
                                   FontFamily="Courier New" FontSize="20" FontWeight="Bold"
                                   Foreground="#00FF41"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,16,0"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="LblLanguage"
                                       Text="{loc:Loc LANGUAGE_LABEL}"
                                       FontFamily="Courier New" FontSize="11"
                                       Foreground="#00AA30"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="CmbLanguage"
                                      Width="116" Height="26"
                                      FontFamily="Courier New" FontSize="11"
                                      Background="#0A150A"
                                      Foreground="#00FF41"
                                      BorderBrush="#00AA30"
                                      SelectionChanged="CmbLanguage_SelectionChanged">
                                <ComboBoxItem Content="Español" Tag="es-MX"/>
                                <ComboBoxItem Content="English" Tag="en-US"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                    <Border Background="#007A1F" Height="1" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- 3x2 Menu grid -->
                <UniformGrid Grid.Row="2" Rows="3" Columns="2" Margin="28,18,28,18">

                    <!-- Lista de Partidas -->
                    <Button Style="{StaticResource MenuButton}" Margin="8" Click="BtnGameList_Click">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16,0,16">
                            <TextBlock Text="[ &gt;&gt; ]"
                                       FontFamily="Courier New" FontSize="24"
                                       Foreground="#00FF41" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc MAIN_MENU_GAME_LIST}"
                                       FontFamily="Courier New" FontSize="14" FontWeight="Bold"
                                       Foreground="#00FF41" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock Text="{loc:Loc MAIN_MENU_GAME_LIST_DESC}"
                                       FontFamily="Courier New" FontSize="10"
                                       Foreground="#00AA30" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Ver Puntaje -->
                    <Button Style="{StaticResource MenuButton}" Margin="8" Click="BtnScore_Click">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16,0,16">
                            <TextBlock Text="[ ## ]"
                                       FontFamily="Courier New" FontSize="24"
                                       Foreground="#00FF41" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc MAIN_MENU_SCORE}"
                                       FontFamily="Courier New" FontSize="14" FontWeight="Bold"
                                       Foreground="#00FF41" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock Text="{loc:Loc MAIN_MENU_SCORE_DESC}"
                                       FontFamily="Courier New" FontSize="10"
                                       Foreground="#00AA30" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Perfil -->
                    <Button Style="{StaticResource MenuButton}" Margin="8" Click="BtnProfile_Click">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16,0,16">
                            <TextBlock Text="[ @@ ]"
                                       FontFamily="Courier New" FontSize="24"
                                       Foreground="#00FF41" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc MAIN_MENU_PROFILE}"
                                       FontFamily="Courier New" FontSize="14" FontWeight="Bold"
                                       Foreground="#00FF41" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock Text="{loc:Loc MAIN_MENU_PROFILE_DESC}"
                                       FontFamily="Courier New" FontSize="10"
                                       Foreground="#00AA30" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Amigos -->
                    <Button Style="{StaticResource MenuButton}" Margin="8" Click="BtnFriends_Click">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16,0,16">
                            <TextBlock Text="[ ++ ]"
                                       FontFamily="Courier New" FontSize="24"
                                       Foreground="#00FF41" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc MAIN_MENU_FRIENDS}"
                                       FontFamily="Courier New" FontSize="14" FontWeight="Bold"
                                       Foreground="#00FF41" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock Text="{loc:Loc MAIN_MENU_FRIENDS_DESC}"
                                       FontFamily="Courier New" FontSize="10"
                                       Foreground="#00AA30" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Cerrar SesiÃ³n -->
                    <Button Style="{StaticResource MenuButton}" Margin="8" Click="BtnLogout_Click">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16,0,16">
                            <TextBlock Text="[ XX ]"
                                       FontFamily="Courier New" FontSize="24"
                                       Foreground="#FF6666" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc MAIN_MENU_LOGOUT}"
                                       FontFamily="Courier New" FontSize="14" FontWeight="Bold"
                                       Foreground="#FF6666" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock Text="{loc:Loc MAIN_MENU_LOGOUT_DESC}"
                                       FontFamily="Courier New" FontSize="10"
                                       Foreground="#AA3333" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Leaderboard -->
                    <Button Style="{StaticResource MenuButton}" Margin="8" Click="BtnLeaderboard_Click">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16,0,16">
                            <TextBlock Text="[ TOP ]"
                                       FontFamily="Courier New" FontSize="24"
                                       Foreground="#00FF41" HorizontalAlignment="Center"/>
                            <TextBlock Text="LEADERBOARD"
                                       FontFamily="Courier New" FontSize="14" FontWeight="Bold"
                                       Foreground="#00FF41" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock Text="{loc:Loc MAIN_MENU_LEADERBOARD_DESC}"
                                       FontFamily="Courier New" FontSize="10"
                                       Foreground="#00AA30" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                </UniformGrid>

                <!-- Footer -->
                <Border Grid.Row="3" Background="#001200" BorderBrush="#00FF41" BorderThickness="0,1,0,0">
                    <TextBlock Text="{loc:Loc FOOTER_RIGHTS_SHORT}"
                               FontFamily="Courier New" FontSize="10" Foreground="#007A1F"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Rectangle IsHitTestVisible="False" Panel.ZIndex="100">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile" Viewport="0,0,1,4" ViewportUnits="Absolute"
                              Viewbox="0,0,1,4" ViewboxUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="#18000000">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,1,2"/>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Window>

