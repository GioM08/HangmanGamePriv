<Window x:Class="HangmanGameWPF.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HANGMAN - REGISTRO"
        Height="640" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0C0C0C">
    <Grid>
        <Border BorderBrush="#00FF41" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0" Background="#001A00"
                        BorderBrush="#00FF41" BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="[ HANGMAN TERMINAL  v1.0 ]  --  NUEVO USUARIO"
                                   FontFamily="Courier New" FontSize="11"
                                   Foreground="#00AA30"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <Button Content="[X]" Style="{StaticResource ChromeButton}"
                                Foreground="#FF6666" Click="BtnClose_Click"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Margin="0,0,6,0"/>
                    </Grid>
                </Border>

                <!-- Form -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="36,20,36,20">
                        <TextBlock Text="&gt; CREAR CUENTA"
                                   FontFamily="Courier New" FontSize="19" FontWeight="Bold"
                                   Foreground="#00FF41" Margin="0,0,0,6"/>
                        <Border Background="#00FF41" Height="1" Margin="0,0,0,18"/>

                        <TextBlock Text="NOMBRE COMPLETO:" FontFamily="Courier New" FontSize="12"
                                   Foreground="#00AA30" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtFullName" Height="40"
                                 Style="{StaticResource RetroTextBox}" Margin="0,0,0,12"/>

                        <TextBlock Text="FECHA DE NACIMIENTO:" FontFamily="Courier New" FontSize="12"
                                   Foreground="#00AA30" Margin="0,0,0,4"/>
                        <DatePicker x:Name="DpBirthDate" Height="40" Margin="0,0,0,12"
                                    Background="#0A150A" Foreground="#00FF41"
                                    BorderBrush="#00AA30" FontFamily="Courier New" FontSize="13"/>

                        <TextBlock Text="TELEFONO:" FontFamily="Courier New" FontSize="12"
                                   Foreground="#00AA30" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtPhone" Height="40"
                                 Style="{StaticResource RetroTextBox}" Margin="0,0,0,12"/>

                        <TextBlock Text="CORREO ELECTRONICO:" FontFamily="Courier New" FontSize="12"
                                   Foreground="#00AA30" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtEmail" Height="40"
                                 Style="{StaticResource RetroTextBox}" Margin="0,0,0,12"/>

                        <TextBlock Text="CONTRASENA:" FontFamily="Courier New" FontSize="12"
                                   Foreground="#00AA30" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="PbPassword" Height="40"
                                     Style="{StaticResource RetroPasswordBox}" Margin="0,0,0,12"/>

                        <TextBlock Text="CONFIRMAR CONTRASENA:" FontFamily="Courier New" FontSize="12"
                                   Foreground="#00AA30" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="PbConfirm" Height="40"
                                     Style="{StaticResource RetroPasswordBox}" Margin="0,0,0,16"/>

                        <TextBlock x:Name="TxtMessage" Text=""
                                   FontFamily="Courier New" FontSize="11"
                                   Foreground="#FF4444" Margin="0,0,0,14"
                                   TextWrapping="Wrap"/>

                        <Button Content="[ CREAR CUENTA ]"
                                Style="{StaticResource RetroButton}"
                                Height="40" Margin="0,0,0,10"
                                Click="BtnCreate_Click"/>

                        <Button Content="[ CANCELAR ]"
                                Style="{StaticResource RetroButton}"
                                Height="36" Click="BtnCancel_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="2" Background="#001200"
                        BorderBrush="#00FF41" BorderThickness="0,1,0,0">
                    <TextBlock Text="(C) 2024 HANGMAN CORP  |  REGISTRO DE USUARIO"
                               FontFamily="Courier New" FontSize="10" Foreground="#007A1F"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Scanlines CRT overlay -->
        <Rectangle IsHitTestVisible="False" Panel.ZIndex="100">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile"
                              Viewport="0,0,1,4" ViewportUnits="Absolute"
                              Viewbox="0,0,1,4"   ViewboxUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="#18000000">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,1,2"/>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Window>
