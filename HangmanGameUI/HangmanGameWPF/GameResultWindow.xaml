<Window x:Class="HangmanGameWPF.GameResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HANGMAN - RESULTADO"
        Height="360" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0C0C0C">
    <Grid>
        <Border BorderBrush="#00FF41" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#001A00" BorderBrush="#00FF41" BorderThickness="0,0,0,1">
                    <TextBlock Text="[ HANGMAN TERMINAL  v1.0 ]  --  RESULTADO DE PARTIDA"
                               FontFamily="Courier New" FontSize="11" Foreground="#00AA30"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="40,20,40,20">
                    <TextBlock x:Name="TxtTitle"
                               FontFamily="Courier New" FontSize="36" FontWeight="Bold"
                               Foreground="#00FF41" HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    <Border Background="#00FF41" Height="1" Margin="0,0,0,20"/>

                    <TextBlock x:Name="TxtResultMsg"
                               FontFamily="Courier New" FontSize="14"
                               Foreground="#00AA30" TextAlignment="Center"
                               TextWrapping="Wrap" HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <TextBlock Text="PUNTOS OBTENIDOS: " FontFamily="Courier New" FontSize="16"
                                   Foreground="#00AA30"/>
                        <TextBlock x:Name="TxtPoints" FontFamily="Courier New" FontSize="16"
                                   FontWeight="Bold" Foreground="#00FF41"/>
                    </StackPanel>

                    <Button Content="[ CONTINUAR ]"
                            Style="{StaticResource RetroButton}"
                            Height="40" Click="BtnContinue_Click"/>
                </StackPanel>

                <Border Grid.Row="2" Background="#001200" BorderBrush="#00FF41" BorderThickness="0,1,0,0">
                    <TextBlock Text="(C) 2024 HANGMAN CORP  |  FIN DE PARTIDA"
                               FontFamily="Courier New" FontSize="10" Foreground="#007A1F"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Rectangle IsHitTestVisible="False" Panel.ZIndex="100">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile" Viewport="0,0,1,4" ViewportUnits="Absolute"
                              Viewbox="0,0,1,4" ViewboxUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="#18000000">
                            <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,1,2"/></GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Window>
