<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>

  <system.serviceModel>
    <bindings>
      <basicHttpBinding>
        <binding name="BasicHttpBinding_IUserService" maxReceivedMessageSize="2147483647">
          <readerQuotas maxStringContentLength="2147483647" />
        </binding>

        <binding name="BasicHttpBinding_ICategoryService" maxReceivedMessageSize="2147483647">
          <readerQuotas maxStringContentLength="2147483647" />
        </binding>

        <binding name="BasicHttpBinding_IFriendService" maxReceivedMessageSize="2147483647">
          <readerQuotas maxStringContentLength="2147483647" />
        </binding>

        <binding name="BasicHttpBinding_ILeaderboardService" maxReceivedMessageSize="2147483647">
          <readerQuotas maxStringContentLength="2147483647" />
        </binding>

        <binding name="BasicHttpBinding_IAccountRecoveryService" maxReceivedMessageSize="2147483647">
          <readerQuotas maxStringContentLength="2147483647" />
        </binding>
      </basicHttpBinding>

      <wsDualHttpBinding>
        <binding name="WsDualHttpBinding_IGameService" maxReceivedMessageSize="2147483647">
          <readerQuotas maxStringContentLength="2147483647" />
          <security mode="None" />
        </binding>
      </wsDualHttpBinding>
    </bindings>

    <client>
      <endpoint address="http://localhost:62627/Services/UserService.svc"
                binding="basicHttpBinding"
                bindingConfiguration="BasicHttpBinding_IUserService"
                contract="HangmanGameWPF.Services.IUserService"
                name="BasicHttpBinding_IUserService" />

      <endpoint address="http://localhost:62627/Services/CategoryService.svc"
                binding="basicHttpBinding"
                bindingConfiguration="BasicHttpBinding_ICategoryService"
                contract="HangmanGameWPF.Services.ICategoryService"
                name="BasicHttpBinding_ICategoryService" />

      <endpoint address="http://localhost:62627/Services/FriendService.svc"
                binding="basicHttpBinding"
                bindingConfiguration="BasicHttpBinding_IFriendService"
                contract="HangmanGameWPF.Services.IFriendService"
                name="BasicHttpBinding_IFriendService" />

      <endpoint address="http://localhost:62627/Services/LeaderboardService.svc"
                binding="basicHttpBinding"
                bindingConfiguration="BasicHttpBinding_ILeaderboardService"
                contract="HangmanGameWPF.Services.ILeaderboardService"
                name="BasicHttpBinding_ILeaderboardService" />

      <endpoint address="http://localhost:62627/Services/AccountRecoveryService.svc"
                binding="basicHttpBinding"
                bindingConfiguration="BasicHttpBinding_IAccountRecoveryService"
                contract="HangmanGameWPF.Services.IAccountRecoveryService"
                name="BasicHttpBinding_IAccountRecoveryService" />

      <endpoint address="http://localhost:62627/Services/GameService.svc"
                binding="wsDualHttpBinding"
                bindingConfiguration="WsDualHttpBinding_IGameService"
                contract="HangmanGameWPF.Services.IGameService"
                name="WsDualHttpBinding_IGameService" />
    </client>
  </system.serviceModel>
</configuration>
