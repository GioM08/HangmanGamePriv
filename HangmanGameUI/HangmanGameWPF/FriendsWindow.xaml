<Window x:Class="HangmanGameWPF.FriendsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HangmanGameWPF.Localization"
        Title="FRIENDS TERMINAL"
        Height="620" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0C0C0C">

    <Grid>
        <Border BorderBrush="#00FF41" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="34"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0" Background="#001A00"
                        BorderBrush="#00FF41" BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="{loc:Loc FRIENDS_TITLE_BAR}"
                                   FontFamily="Courier New"
                                   FontSize="11"
                                   Foreground="#00AA30"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,0">
                            <Button Content="[-]"
                                    Style="{StaticResource ChromeButton}"
                                    Click="BtnMinimize_Click"/>
                            <Button Content="[X]"
                                    Style="{StaticResource ChromeButton}"
                                    Foreground="#FF6666"
                                    Margin="4,0,0,0"
                                    Click="BtnClose_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Margin="24,18,24,8">
                    <TextBlock Text="{loc:Loc FRIENDS_TITLE}"
                               FontFamily="Courier New"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#00FF41"/>
                    <TextBlock Text="{loc:Loc FRIENDS_SUBTITLE}"
                               FontFamily="Courier New"
                               FontSize="11"
                               Foreground="#00AA30"
                               Margin="0,4,0,0"/>
                    <Border Background="#007A1F" Height="1" Margin="0,10,0,0"/>
                </StackPanel>

                <Grid Grid.Row="2" Margin="24,8,24,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="150"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{loc:Loc MY_FRIENDS_TITLE}"
                                   FontFamily="Courier New"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#00FF41"
                                   Margin="0,0,0,8"/>

                        <ListBox x:Name="LstFriends"
                                 Grid.Row="1"
                                 Background="#050505"
                                 BorderBrush="#007A1F"
                                 Foreground="#00FF41"
                                 FontFamily="Courier New"
                                 Margin="0,0,0,12">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#003F16"
                                            BorderThickness="0,0,0,1"
                                            Padding="6">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FullName}"
                                                       Foreground="#00FF41"
                                                       FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Email}"
                                                       Foreground="#00AA30"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding GlobalScore, StringFormat=Score: {0}}"
                                                       Foreground="#00FF41"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding FriendsSince, StringFormat=Friends since: {0:dd/MM/yyyy}}"
                                                       Foreground="#007A1F"
                                                       FontSize="10"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,0,12">
                            <Button Content="{loc:Loc REFRESH_BUTTON}"
                                    Style="{StaticResource RetroButton}"
                                    Width="130"
                                    Height="34"
                                    Margin="0,0,8,0"
                                    Click="BtnRefreshFriends_Click"/>

                            <Button Content="{loc:Loc REMOVE_BUTTON}"
                                    Style="{StaticResource RetroButton}"
                                    Width="130"
                                    Height="34"
                                    Foreground="#FF6666"
                                    Click="BtnRemoveFriend_Click"/>
                        </StackPanel>

                        <Border Grid.Row="3"
                                BorderBrush="#007A1F"
                                BorderThickness="1"
                                Padding="12"
                                Background="#050505">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc SEND_REQUEST_TITLE}"
                                           FontFamily="Courier New"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="#00FF41"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="{loc:Loc FRIEND_EMAIL_LABEL}"
           FontFamily="Courier New"
           FontSize="11"
           Foreground="#00AA30"
           Margin="0,0,0,4"/>

                                <TextBox x:Name="TxtReceiverEmail"
         Height="32"
         Style="{StaticResource RetroTextBox}"
         Margin="0,0,0,10"/>

                                <Button Content="{loc:Loc SEND_REQUEST_TITLE}"
                                        Style="{StaticResource RetroButton}"
                                        Height="34"
                                        Click="BtnSendRequest_Click"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                BorderBrush="#007A1F"
                                BorderThickness="1"
                                Padding="12"
                                Background="#050505">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="{loc:Loc RECEIVED_REQUESTS_TITLE}"
                                           FontFamily="Courier New"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="#00FF41"
                                           Margin="0,0,0,8"/>

                                <ListBox x:Name="LstPendingRequests"
                                         Grid.Row="1"
                                         Background="#0C0C0C"
                                         BorderBrush="#003F16"
                                         Foreground="#00FF41"
                                         FontFamily="Courier New"
                                         Margin="0,0,0,10">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4">
                                                <TextBlock Text="{Binding SenderFullName}"
                                                           Foreground="#00FF41"
                                                           FontWeight="Bold"/>
                                                <TextBlock Text="{Binding SenderEmail}"
                                                           Foreground="#00AA30"
                                                           FontSize="11"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat=Fecha: {0:dd/MM/yyyy HH:mm}}"
                                                           Foreground="#007A1F"
                                                           FontSize="10"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel Grid.Row="2"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Button Content="{loc:Loc ACCEPT_BUTTON}"
                                            Style="{StaticResource RetroButton}"
                                            Width="110"
                                            Height="32"
                                            Margin="0,0,8,0"
                                            Click="BtnAcceptRequest_Click"/>
                                    <Button Content="{loc:Loc REJECT_BUTTON}"
                                            Style="{StaticResource RetroButton}"
                                            Width="110"
                                            Height="32"
                                            Click="BtnRejectRequest_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                BorderBrush="#007A1F"
                                BorderThickness="1"
                                Padding="12"
                                Background="#050505">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="{loc:Loc SENT_REQUESTS_TITLE}"
                                           FontFamily="Courier New"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="#00FF41"
                                           Margin="0,0,0,8"/>

                                <ListBox x:Name="LstSentRequests"
                                         Grid.Row="1"
                                         Background="#0C0C0C"
                                         BorderBrush="#003F16"
                                         Foreground="#00FF41"
                                         FontFamily="Courier New"
                                         Margin="0,0,0,10">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4">
                                                <TextBlock Text="{Binding ReceiverFullName}"
                                                           Foreground="#00FF41"
                                                           FontWeight="Bold"/>
                                                <TextBlock Text="{Binding ReceiverEmail}"
                                                           Foreground="#00AA30"
                                                           FontSize="11"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat=Fecha: {0:dd/MM/yyyy HH:mm}}"
                                                           Foreground="#007A1F"
                                                           FontSize="10"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Button Grid.Row="2"
                                        Content="{loc:Loc CANCEL_REQUEST_BUTTON}"
                                        Style="{StaticResource RetroButton}"
                                        Height="32"
                                        HorizontalAlignment="Right"
                                        Width="190"
                                        Click="BtnCancelRequest_Click"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Border Grid.Row="3"
                        Background="#001200"
                        BorderBrush="#00FF41"
                        BorderThickness="0,1,0,0">
                    <TextBlock x:Name="TxtStatus"
                               Text="{loc:Loc READY_LABEL}"
                               FontFamily="Courier New"
                               FontSize="10"
                               Foreground="#007A1F"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Rectangle IsHitTestVisible="False" Panel.ZIndex="100">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile"
                              Viewport="0,0,1,4"
                              ViewportUnits="Absolute"
                              Viewbox="0,0,1,4"
                              ViewboxUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="#18000000">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,1,2"/>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Window>

