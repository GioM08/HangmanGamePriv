<Window x:Class="HangmanGameWPF.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HangmanGameWPF.Localization"
        Title="HANGMAN - PERFIL"
        Height="590" Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0C0C0C">
    <Grid>
        <Border BorderBrush="#00FF41" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0" Background="#001A00" BorderBrush="#00FF41" BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="{loc:Loc PROFILE_TITLE_BAR}"
                                   FontFamily="Courier New" FontSize="11" Foreground="#00AA30"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Margin="0,0,6,0">
                            <Button Content="[-]" Style="{StaticResource ChromeButton}" Click="BtnMinimize_Click"/>
                            <Button Content="[X]" Style="{StaticResource ChromeButton}"
                                    Foreground="#FF6666" Margin="4,0,0,0" Click="BtnClose_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Profile content -->
                <Grid Grid.Row="1" Margin="28,20,28,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="{loc:Loc PROFILE_TITLE}"
                                   FontFamily="Courier New" FontSize="18" FontWeight="Bold"
                                   Foreground="#00FF41" Margin="0,0,0,6"/>
                        <Border Background="#00FF41" Height="1"/>
                    </StackPanel>

                    <!-- Avatar + username block -->
                    <Grid Grid.Row="1" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar box -->
                        <Border Grid.Column="0" Width="80" Height="80"
                                BorderBrush="#00FF41" BorderThickness="2"
                                Background="#001A00" Margin="0,0,20,0">
                            <TextBlock Text="[  ]&#10;[@@]&#10;[  ]"
                                       FontFamily="Courier New" FontSize="16"
                                       Foreground="#00FF41" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" TextAlignment="Center"/>
                        </Border>

                        <!-- Name + role -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtUsername"
                                       FontFamily="Courier New" FontSize="26" FontWeight="Bold"
                                       Foreground="#00FF41"/>
                            <TextBlock Text="{loc:Loc REGISTERED_PLAYER_LABEL}"
                                       FontFamily="Courier New" FontSize="11"
                                       Foreground="#007A1F" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Info fields -->
                    <Grid Grid.Row="2" Margin="0,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Email row -->
                        <Border Grid.Row="0" BorderBrush="#007A1F" BorderThickness="0,0,0,1"
                                Padding="0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{loc:Loc EMAIL_TITLE_LABEL}"
                                           FontFamily="Courier New" FontSize="11"
                                           Foreground="#00AA30" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtEmail" Grid.Column="1"
                                           FontFamily="Courier New" FontSize="14"
                                           Foreground="#00FF41" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Partidas jugadas -->
                        <Border Grid.Row="1" BorderBrush="#007A1F" BorderThickness="0,0,0,1"
                                Padding="0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{loc:Loc GAMES_PLAYED_LABEL}"
                                           FontFamily="Courier New" FontSize="11"
                                           Foreground="#00AA30" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtGamesPlayed" Grid.Column="1" Text="0"
                                           FontFamily="Courier New" FontSize="14"
                                           Foreground="#00FF41" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Partidas ganadas -->
                        <Border Grid.Row="2" BorderBrush="#007A1F" BorderThickness="0,0,0,1"
                                Padding="0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{loc:Loc GAMES_WON_LABEL}"
                                           FontFamily="Courier New" FontSize="11"
                                           Foreground="#00AA30" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtGamesWon"
                                               FontFamily="Courier New" FontSize="14"
                                               Foreground="#00FF41"/>
                                    <TextBlock x:Name="TxtWinRate"
                                               FontFamily="Courier New" FontSize="14"
                                               Foreground="#007A1F"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Estado de verificacion -->
                        <Border Grid.Row="3" BorderBrush="#007A1F" BorderThickness="0,0,0,1"
                                Padding="0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{loc:Loc VERIFICATION_LABEL}"
                                           FontFamily="Courier New" FontSize="11"
                                           Foreground="#00AA30" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtEmailVerificationStatus" Grid.Column="1"
                                           FontFamily="Courier New" FontSize="14"
                                           Foreground="#00FF41" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Stats bar -->
                    <Grid Grid.Row="3" VerticalAlignment="Top" Margin="0,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="TxtProgressLabel" Grid.Row="0" Text="{loc:Loc PROGRESS_INITIAL_LABEL}"
                                   FontFamily="Courier New" FontSize="11"
                                   Foreground="#00AA30" Margin="0,0,0,6"/>
                        <Border Grid.Row="1" Height="16" Background="#0A150A"
                                BorderBrush="#007A1F" BorderThickness="1">
                            <Grid HorizontalAlignment="Left" Width="360">
                                <Rectangle x:Name="RectProgress" Fill="#00FF41" HorizontalAlignment="Left" Width="0"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Buttons -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="{loc:Loc BACK_BUTTON}"
                                Style="{StaticResource RetroButton}" Height="40"
                                Click="BtnBack_Click"/>
                        <Button Grid.Column="2" Content="{loc:Loc EDIT_PROFILE_BUTTON}"
                                Style="{StaticResource RetroButton}" Height="40"
                                Click="BtnEdit_Click"/>
                        <Button x:Name="BtnVerifyEmail" Grid.Column="4" Content="{loc:Loc VERIFY_BUTTON}"
                                Style="{StaticResource RetroButton}" Height="40"
                                Click="BtnVerifyEmail_Click"/>
                    </Grid>
                </Grid>

                <!-- Footer -->
                <Border Grid.Row="2" Background="#001200" BorderBrush="#00FF41" BorderThickness="0,1,0,0">
                    <TextBlock Text="{loc:Loc FOOTER_PROFILE}"
                               FontFamily="Courier New" FontSize="10" Foreground="#007A1F"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Rectangle IsHitTestVisible="False" Panel.ZIndex="100">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile" Viewport="0,0,1,4" ViewportUnits="Absolute"
                              Viewbox="0,0,1,4" ViewboxUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="#18000000">
                            <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,1,2"/></GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Window>

