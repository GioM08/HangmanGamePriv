<Window x:Class="HangmanGameWPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HangmanGameWPF.Localization"
        Title="HANGMAN TERMINAL"
        Height="520" Width="780"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0C0C0C">
    <Grid>
        <Border BorderBrush="#00FF41" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- Custom title bar (draggable) -->
                <Border Grid.Row="0" Background="#001A00"
                        BorderBrush="#00FF41" BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock x:Name="TxtTitleBar"
                                   Text="{loc:Loc LOGIN_TITLE_BAR}"
                                   FontFamily="Courier New" FontSize="11"
                                   Foreground="#00AA30"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Margin="0,0,6,0">
                            <Button Content="[-]" Style="{StaticResource ChromeButton}"
                                    Click="BtnMinimize_Click"/>
                            <Button Content="[X]" Style="{StaticResource ChromeButton}"
                                    Foreground="#FF6666" Margin="4,0,0,0"
                                    Click="BtnClose_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main content -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Art panel -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="20,0,16,0">
                        <TextBlock Text="HANGMAN"
                                   FontFamily="Courier New" FontSize="46" FontWeight="Bold"
                                   Foreground="#00FF41" HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                        <Border Background="#007A1F" Height="1" Margin="10,8,10,14"/>
                        <Image Source="pack://application:,,,/Resources/HangmanIcon.png"
                               Width="200" Height="200"
                               HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock x:Name="BlinkText"
                                   Text="{loc:Loc LOGIN_WAITING}"
                                   FontFamily="Courier New" FontSize="11"
                                   Foreground="#00AA30" HorizontalAlignment="Center"
                                   Margin="0,14,0,0"/>
                    </StackPanel>

                    <!-- Vertical divider -->
                    <Border Grid.Column="1" Background="#007A1F"/>

                    <!-- Right: Login form -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="30,0,30,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
                            <TextBlock x:Name="LblLanguage"
                                       Text="{loc:Loc LANGUAGE_LABEL}"
                                       FontFamily="Courier New" FontSize="11"
                                       Foreground="#00AA30"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="CmbLanguage"
                                      Width="116" Height="26"
                                      FontFamily="Courier New" FontSize="11"
                                      Background="#0A150A"
                                      Foreground="#00FF41"
                                      BorderBrush="#00AA30"
                                      SelectionChanged="CmbLanguage_SelectionChanged">
                                <ComboBoxItem Content="EspaÃ±ol" Tag="es-MX"/>
                                <ComboBoxItem Content="English" Tag="en-US"/>
                            </ComboBox>
                        </StackPanel>

                        <TextBlock x:Name="TxtLoginTitle"
                                   Text="{loc:Loc LOGIN_TITLE}"
                                   FontFamily="Courier New" FontSize="19" FontWeight="Bold"
                                   Foreground="#00FF41" Margin="0,0,0,6"/>
                        <Border Background="#00FF41" Height="1" Margin="0,0,0,22"/>

                        <TextBlock x:Name="LblEmail"
                                   Text="{loc:Loc EMAIL_LABEL}" FontFamily="Courier New" FontSize="12"
                                   Foreground="#00AA30" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtEmail" Height="40"
                                 Style="{StaticResource RetroTextBox}"
                                 Margin="0,0,0,14" KeyDown="Input_KeyDown"/>

                        <TextBlock x:Name="LblPassword"
                                   Text="{loc:Loc PASSWORD_LABEL}" FontFamily="Courier New" FontSize="12"
                                   Foreground="#00AA30" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="PbPassword" Height="40"
                                     Style="{StaticResource RetroPasswordBox}"
                                     Margin="0,0,0,18" KeyDown="Input_KeyDown"/>

                        <TextBlock x:Name="TxtError" Text=""
                                   FontFamily="Courier New" FontSize="11"
                                   Foreground="#FF4444" Margin="0,0,0,10"
                                   TextWrapping="Wrap"/>

                        <Button x:Name="BtnLogin"
                                Content="{loc:Loc LOGIN_BUTTON}"
                                Style="{StaticResource RetroButton}"
                                Height="40" Margin="0,0,0,14"
                                Click="BtnLogin_Click"/>

                        <Button x:Name="BtnForgotPassword"
                                Content="{loc:Loc FORGOT_PASSWORD_BUTTON}"
                                Style="{StaticResource LinkButton}"
                                Margin="0,0,0,14"
                                Click="BtnForgotPassword_Click"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtNoAccount"
                                       Text="{loc:Loc LOGIN_NO_ACCOUNT}" FontFamily="Courier New"
                                       FontSize="12" Foreground="#007A1F"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="BtnRegister"
                                    Content="{loc:Loc REGISTER_BUTTON}"
                                    Style="{StaticResource LinkButton}"
                                    Click="BtnRegister_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Footer -->
                <Border Grid.Row="2" Background="#001200"
                        BorderBrush="#00FF41" BorderThickness="0,1,0,0">
                    <TextBlock x:Name="TxtFooter"
                               Text="{loc:Loc FOOTER_RIGHTS}"
                               FontFamily="Courier New" FontSize="10" Foreground="#007A1F"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Scanlines CRT overlay -->
        <Rectangle IsHitTestVisible="False" Panel.ZIndex="100">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile"
                              Viewport="0,0,1,4" ViewportUnits="Absolute"
                              Viewbox="0,0,1,4"   ViewboxUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="#18000000">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,1,2"/>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Window>

