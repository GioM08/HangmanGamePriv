<Window x:Class="HangmanGameWPF.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FORGOT PASSWORD"
        Height="390" Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0C0C0C">

    <Grid>
        <Border BorderBrush="#00FF41" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#001A00"
                        BorderBrush="#00FF41"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="[ PASSWORD RECOVERY ]"
                                   FontFamily="Courier New"
                                   FontSize="11"
                                   Foreground="#00AA30"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,0">
                            <Button Content="[-]"
                                    Style="{StaticResource ChromeButton}"
                                    Click="BtnMinimize_Click"/>
                            <Button Content="[X]"
                                    Style="{StaticResource ChromeButton}"
                                    Foreground="#FF6666"
                                    Margin="4,0,0,0"
                                    Click="BtnClose_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center"
                            Margin="42,0,42,0">

                    <TextBlock Text="&gt; RECUPERAR CONTRASENA"
                               FontFamily="Courier New"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#00FF41"/>

                    <TextBlock Text="Ingresa tu correo. Si existe, se enviara un codigo de recuperacion."
                               FontFamily="Courier New"
                               FontSize="12"
                               Foreground="#00AA30"
                               TextWrapping="Wrap"
                               Margin="0,8,0,20"/>

                    <TextBlock Text="CORREO ELECTRONICO:"
                               FontFamily="Courier New"
                               FontSize="12"
                               Foreground="#00AA30"
                               Margin="0,0,0,4"/>

                    <TextBox x:Name="TxtEmail"
                             Height="40"
                             Style="{StaticResource RetroTextBox}"
                             Margin="0,0,0,14"/>

                    <TextBlock x:Name="TxtStatus"
                               FontFamily="Courier New"
                               FontSize="11"
                               Foreground="#FF4444"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <Button Content="[ ENVIAR CODIGO ]"
                            Style="{StaticResource RetroButton}"
                            Height="40"
                            Click="BtnSendCode_Click"/>
                </StackPanel>

                <Border Grid.Row="2"
                        Background="#001200"
                        BorderBrush="#00FF41"
                        BorderThickness="0,1,0,0">
                    <TextBlock Text="HANGMAN GAME AUTH MODULE"
                               FontFamily="Courier New"
                               FontSize="10"
                               Foreground="#007A1F"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
