<Window x:Class="HangmanGameWPF.LeaderboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HangmanGameWPF.Localization"
        Title="LEADERBOARD TERMINAL"
        Height="560" Width="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0C0C0C">

    <Grid>
        <Border BorderBrush="#00FF41" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="34"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0"
                        Background="#001A00"
                        BorderBrush="#00FF41"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="{loc:Loc LEADERBOARD_TITLE_BAR}"
                                   FontFamily="Courier New"
                                   FontSize="11"
                                   Foreground="#00AA30"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,0">
                            <Button Content="[-]"
                                    Style="{StaticResource ChromeButton}"
                                    Click="BtnMinimize_Click"/>
                            <Button Content="[X]"
                                    Style="{StaticResource ChromeButton}"
                                    Foreground="#FF6666"
                                    Margin="4,0,0,0"
                                    Click="BtnClose_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Header -->
                <StackPanel Grid.Row="1" Margin="24,18,24,8">
                    <TextBlock Text="{loc:Loc LEADERBOARD_HEADER}"
                               FontFamily="Courier New"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#00FF41"/>

                    <TextBlock Text="{loc:Loc LEADERBOARD_SUBTITLE}"
                               FontFamily="Courier New"
                               FontSize="11"
                               Foreground="#00AA30"
                               Margin="0,4,0,0"/>

                    <Border Background="#007A1F" Height="1" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Top players -->
                <Border Grid.Row="2"
                        Margin="24,8,24,14"
                        BorderBrush="#007A1F"
                        BorderThickness="1"
                        Background="#050505"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{loc:Loc LEADERBOARD_POS}"
                                       FontFamily="Courier New"
                                       FontWeight="Bold"
                                       Foreground="#00FF41"/>

                            <TextBlock Grid.Column="1"
                                       Text="{loc:Loc LEADERBOARD_PLAYER}"
                                       FontFamily="Courier New"
                                       FontWeight="Bold"
                                       Foreground="#00FF41"/>

                            <TextBlock Grid.Column="2"
                                       Text="{loc:Loc LEADERBOARD_SCORE}"
                                       FontFamily="Courier New"
                                       FontWeight="Bold"
                                       Foreground="#00FF41"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <ListBox x:Name="LstTopPlayers"
                                 Grid.Row="1"
                                 Background="#0C0C0C"
                                 BorderBrush="#003F16"
                                 Foreground="#00FF41"
                                 FontFamily="Courier New">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#003F16"
                                            BorderThickness="0,0,0,1"
                                            Padding="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Position, StringFormat=# {0}}"
                                                       Foreground="#00FF41"
                                                       FontWeight="Bold"/>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding FullName}"
                                                       Foreground="#00FF41"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding GlobalScore}"
                                                       Foreground="#00FF41"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Current player rank -->
                <Border Grid.Row="3"
                        Margin="24,0,24,14"
                        BorderBrush="#00FF41"
                        BorderThickness="1"
                        Background="#050505"
                        Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc LEADERBOARD_CURRENT_PLAYER}"
                                       FontFamily="Courier New"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="#00FF41"/>

                            <TextBlock x:Name="TxtCurrentPlayer"
                                       Text="{loc:Loc LOADING_LABEL}"
                                       FontFamily="Courier New"
                                       FontSize="12"
                                       Foreground="#00AA30"
                                       Margin="0,8,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="{loc:Loc REFRESH_BUTTON}"
                                Style="{StaticResource RetroButton}"
                                Width="140"
                                Height="34"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Click="BtnRefresh_Click"/>
                    </Grid>
                </Border>

                <!-- Footer -->
                <Border Grid.Row="4"
                        Background="#001200"
                        BorderBrush="#00FF41"
                        BorderThickness="0,1,0,0">
                    <TextBlock x:Name="TxtStatus"
                               Text="{loc:Loc READY_LABEL}"
                               FontFamily="Courier New"
                               FontSize="10"
                               Foreground="#007A1F"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Scanlines -->
        <Rectangle IsHitTestVisible="False" Panel.ZIndex="100">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile"
                              Viewport="0,0,1,4"
                              ViewportUnits="Absolute"
                              Viewbox="0,0,1,4"
                              ViewboxUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="#18000000">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,1,2"/>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Window>

