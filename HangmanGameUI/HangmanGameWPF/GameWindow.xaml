<Window x:Class="HangmanGameWPF.GameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HangmanGameWPF.Localization"
        Title="HANGMAN - JUGAR"
        Height="680" Width="1060"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0C0C0C">
    <Grid>
        <Border BorderBrush="#00FF41" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0" Background="#001A00" BorderBrush="#00FF41" BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock x:Name="TxtTitleBar"
                                   Text="{loc:Loc GAME_TITLE_BAR}"
                                   FontFamily="Courier New" FontSize="11" Foreground="#00AA30"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Margin="0,0,6,0">
                            <Button Content="[-]" Style="{StaticResource ChromeButton}" Click="BtnMinimize_Click"/>
                            <Button Content="[X]" Style="{StaticResource ChromeButton}"
                                    Foreground="#FF6666" Margin="4,0,0,0" Click="BtnClose_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main game area -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="270"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT PANEL: Hangman + stats -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="14,0,14,0">
                        <!-- Hangman ASCII art display -->
                        <Border BorderBrush="#007A1F" BorderThickness="1" Background="#050F05"
                                Margin="0,0,0,10" Padding="10,6">
                            <TextBlock x:Name="TxtHangman"
                                       Text="  +---+&#x0a;  |   |&#x0a;      |&#x0a;      |&#x0a;      |&#x0a;      |&#x0a;========="
                                       FontFamily="Courier New" FontSize="16" FontWeight="Bold"
                                       Foreground="#00FF41" HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                        </Border>

                        <Border Background="#007A1F" Height="1" Margin="0,0,0,10"/>

                        <!-- Vidas -->
                        <TextBlock x:Name="TxtLives"
                                   Text="VIDAS: 6 / 6"
                                   FontFamily="Courier New" FontSize="12"
                                   Foreground="#00AA30" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <Border Background="#007A1F" Height="1" Margin="0,0,0,10"/>

                        <!-- Game info -->
                        <TextBlock x:Name="LblCategory"
                                   Text="{loc:Loc GAME_CATEGORY_LABEL}" FontFamily="Courier New" FontSize="11"
                                   Foreground="#00AA30" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtCategory" FontFamily="Courier New" FontSize="13"
                                   Foreground="#00FF41" Margin="0,0,0,8"/>
                        <TextBlock x:Name="LblDescription"
                                   Text="{loc:Loc DESCRIPTION_LABEL}" FontFamily="Courier New" FontSize="11"
                                   Foreground="#00AA30" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtDescription" FontFamily="Courier New" FontSize="11"
                                   Foreground="#00FF41" TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <TextBlock x:Name="LblPlayer"
                                   Text="{loc:Loc GAME_PLAYER_LABEL}" FontFamily="Courier New" FontSize="11"
                                   Foreground="#00AA30" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtPlayer" FontFamily="Courier New" FontSize="13"
                                   Foreground="#00FF41" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtRole" FontFamily="Courier New" FontSize="11"
                                   Foreground="#007A1F" Margin="0,0,0,8"/>

                        <Border Background="#007A1F" Height="1" Margin="0,0,0,8"/>

                        <TextBlock x:Name="LblWrongLetters"
                                   Text="{loc:Loc GAME_WRONG_LETTERS}" FontFamily="Courier New"
                                   FontSize="11" Foreground="#00AA30" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtWrongLetters" FontFamily="Courier New" FontSize="14"
                                   Foreground="#FF6666" HorizontalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#007A1F"/>

                    <!-- CENTER PANEL: Word + keyboard -->
                    <Grid Grid.Column="2" Margin="18,14,18,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Word display -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock x:Name="LblGuessWord"
                                       Text="{loc:Loc GAME_GUESS_WORD}"
                                       FontFamily="Courier New" FontSize="12"
                                       Foreground="#00AA30" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtRevealedWord"
                                       Text="_ _ _ _ _ _ _ _"
                                       FontFamily="Courier New" FontSize="32" FontWeight="Bold"
                                       Foreground="#00FF41" HorizontalAlignment="Center"
                                       TextAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtWordLength"
                                       FontFamily="Courier New" FontSize="11"
                                       Foreground="#007A1F" HorizontalAlignment="Center"
                                       Margin="0,6,0,0"/>
                            <TextBlock x:Name="TxtMessage"
                                       FontFamily="Courier New" FontSize="12"
                                       Foreground="#00FF41" HorizontalAlignment="Center"
                                       Margin="0,8,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="#007A1F" Height="1" Margin="0,0,0,16"/>

                        <!-- Keyboard -->
                        <StackPanel x:Name="PanelKeyboard" Grid.Row="2" VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock x:Name="LblKeyboard"
                                       Text="{loc:Loc GAME_KEYBOARD}" FontFamily="Courier New" FontSize="11"
                                       Foreground="#00AA30" HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,2">
                                <Button x:Name="BtnQ" Content="Q" Style="{StaticResource KeyboardKey}" Tag="Q" Click="KeyButton_Click"/>
                                <Button x:Name="BtnW" Content="W" Style="{StaticResource KeyboardKey}" Tag="W" Click="KeyButton_Click"/>
                                <Button x:Name="BtnE" Content="E" Style="{StaticResource KeyboardKey}" Tag="E" Click="KeyButton_Click"/>
                                <Button x:Name="BtnR" Content="R" Style="{StaticResource KeyboardKey}" Tag="R" Click="KeyButton_Click"/>
                                <Button x:Name="BtnT" Content="T" Style="{StaticResource KeyboardKey}" Tag="T" Click="KeyButton_Click"/>
                                <Button x:Name="BtnY" Content="Y" Style="{StaticResource KeyboardKey}" Tag="Y" Click="KeyButton_Click"/>
                                <Button x:Name="BtnU" Content="U" Style="{StaticResource KeyboardKey}" Tag="U" Click="KeyButton_Click"/>
                                <Button x:Name="BtnI" Content="I" Style="{StaticResource KeyboardKey}" Tag="I" Click="KeyButton_Click"/>
                                <Button x:Name="BtnO" Content="O" Style="{StaticResource KeyboardKey}" Tag="O" Click="KeyButton_Click"/>
                                <Button x:Name="BtnP" Content="P" Style="{StaticResource KeyboardKey}" Tag="P" Click="KeyButton_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,2">
                                <Button x:Name="BtnA" Content="A" Style="{StaticResource KeyboardKey}" Tag="A" Click="KeyButton_Click"/>
                                <Button x:Name="BtnS" Content="S" Style="{StaticResource KeyboardKey}" Tag="S" Click="KeyButton_Click"/>
                                <Button x:Name="BtnD" Content="D" Style="{StaticResource KeyboardKey}" Tag="D" Click="KeyButton_Click"/>
                                <Button x:Name="BtnF" Content="F" Style="{StaticResource KeyboardKey}" Tag="F" Click="KeyButton_Click"/>
                                <Button x:Name="BtnG" Content="G" Style="{StaticResource KeyboardKey}" Tag="G" Click="KeyButton_Click"/>
                                <Button x:Name="BtnH" Content="H" Style="{StaticResource KeyboardKey}" Tag="H" Click="KeyButton_Click"/>
                                <Button x:Name="BtnJ" Content="J" Style="{StaticResource KeyboardKey}" Tag="J" Click="KeyButton_Click"/>
                                <Button x:Name="BtnK" Content="K" Style="{StaticResource KeyboardKey}" Tag="K" Click="KeyButton_Click"/>
                                <Button x:Name="BtnL" Content="L" Style="{StaticResource KeyboardKey}" Tag="L" Click="KeyButton_Click"/>
                                <Button x:Name="BtnEnie" Content="Ñ" Style="{StaticResource KeyboardKey}" Tag="Ñ" Click="KeyButton_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button x:Name="BtnZ" Content="Z" Style="{StaticResource KeyboardKey}" Tag="Z" Click="KeyButton_Click"/>
                                <Button x:Name="BtnX" Content="X" Style="{StaticResource KeyboardKey}" Tag="X" Click="KeyButton_Click"/>
                                <Button x:Name="BtnC" Content="C" Style="{StaticResource KeyboardKey}" Tag="C" Click="KeyButton_Click"/>
                                <Button x:Name="BtnV" Content="V" Style="{StaticResource KeyboardKey}" Tag="V" Click="KeyButton_Click"/>
                                <Button x:Name="BtnB" Content="B" Style="{StaticResource KeyboardKey}" Tag="B" Click="KeyButton_Click"/>
                                <Button x:Name="BtnN" Content="N" Style="{StaticResource KeyboardKey}" Tag="N" Click="KeyButton_Click"/>
                                <Button x:Name="BtnM" Content="M" Style="{StaticResource KeyboardKey}" Tag="M" Click="KeyButton_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Surrender button -->
                        <Button x:Name="BtnSurrender"
                                Grid.Row="3" Content="{loc:Loc GAME_SURRENDER}"
                                Style="{StaticResource RetroButton}"
                                Height="36" Width="160"
                                HorizontalAlignment="Center"
                                Margin="0,14,0,0"
                                Foreground="#FF6666"
                                Click="BtnSurrender_Click"/>
                    </Grid>

                    <Border Grid.Column="3" Background="#007A1F"/>

                    <!-- RIGHT PANEL: Chat -->
                    <Grid Grid.Column="4" Margin="10,10,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right"
                                    Margin="0,0,0,8">
                            <TextBlock x:Name="LblLanguage"
                                       Text="{loc:Loc LANGUAGE_LABEL}"
                                       FontFamily="Courier New" FontSize="11"
                                       Foreground="#00AA30"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="CmbLanguage"
                                      Width="116" Height="26"
                                      FontFamily="Courier New" FontSize="11"
                                      Background="#0A150A"
                                      Foreground="#00FF41"
                                      BorderBrush="#00AA30"
                                      SelectionChanged="CmbLanguage_SelectionChanged">
                                <ComboBoxItem Content="EspaÃ±ol" Tag="es-MX"/>
                                <ComboBoxItem Content="English" Tag="en-US"/>
                            </ComboBox>
                        </StackPanel>

                        <TextBlock x:Name="LblChat"
                                   Grid.Row="1" Text="{loc:Loc CHAT_HEADER}"
                                   FontFamily="Courier New" FontSize="13" FontWeight="Bold"
                                   Foreground="#00FF41" Margin="0,0,0,8"/>

                        <Border Grid.Row="2" BorderBrush="#007A1F" BorderThickness="1"
                                Background="#050F05">
                            <ScrollViewer x:Name="ChatScroll" VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="TxtChat"
                                           FontFamily="Courier New" FontSize="11"
                                           Foreground="#00AA30" TextWrapping="Wrap"
                                           Padding="6"/>
                            </ScrollViewer>
                        </Border>

                        <TextBox x:Name="TxtChatInput" Grid.Row="3"
                                 Style="{StaticResource RetroTextBox}"
                                 Height="40" Margin="0,8,0,6"
                                 KeyDown="TxtChatInput_KeyDown"/>
                        <Button x:Name="BtnSendChat"
                                Grid.Row="4" Content="{loc:Loc GAME_SEND}"
                                Style="{StaticResource RetroButton}" Height="32"
                                Click="BtnSendChat_Click"/>
                    </Grid>
                </Grid>

                <!-- Legend -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="0,6,0,6">
                    <Border Width="16" Height="16" Background="#003B10" BorderBrush="#00FF41"
                            BorderThickness="1" Margin="0,0,6,0"/>
                    <TextBlock x:Name="LblCorrect"
                               Text="{loc:Loc GAME_CORRECT}" FontFamily="Courier New" FontSize="11"
                               Foreground="#00AA30" Margin="0,0,18,0"/>
                    <Border Width="16" Height="16" Background="#1A0505" BorderBrush="#5A1515"
                            BorderThickness="1" Margin="0,0,6,0"/>
                    <TextBlock x:Name="LblIncorrect"
                               Text="{loc:Loc GAME_INCORRECT}" FontFamily="Courier New" FontSize="11"
                               Foreground="#00AA30" Margin="0,0,18,0"/>
                    <Border Width="16" Height="16" Background="#0C0C0C" BorderBrush="#00AA30"
                            BorderThickness="1" Margin="0,0,6,0"/>
                    <TextBlock x:Name="LblAvailable"
                               Text="{loc:Loc GAME_AVAILABLE}" FontFamily="Courier New" FontSize="11"
                               Foreground="#00AA30"/>
                </StackPanel>

                <!-- Footer -->
                <Border Grid.Row="3" Background="#001200" BorderBrush="#00FF41" BorderThickness="0,1,0,0">
                    <TextBlock x:Name="TxtFooter"
                               Text="{loc:Loc FOOTER_CLICK_LETTER}"
                               FontFamily="Courier New" FontSize="10" Foreground="#007A1F"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Rectangle IsHitTestVisible="False" Panel.ZIndex="100">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile" Viewport="0,0,1,4" ViewportUnits="Absolute"
                              Viewbox="0,0,1,4" ViewboxUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="#18000000">
                            <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,1,2"/></GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Window>

