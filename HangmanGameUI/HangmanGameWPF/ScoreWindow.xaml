<Window x:Class="HangmanGameWPF.ScoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HangmanGameWPF.Localization"
        Title="HANGMAN - PUNTAJE"
        Height="560" Width="860"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#0C0C0C">
    <Grid>
        <Border BorderBrush="#00FF41" BorderThickness="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <!-- Title bar -->
                <Border Grid.Row="0" Background="#001A00" BorderBrush="#00FF41" BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <TextBlock Text="{loc:Loc SCORE_TITLE_BAR}"
                                   FontFamily="Courier New" FontSize="11" Foreground="#00AA30"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center" Margin="0,0,6,0">
                            <Button Content="[-]" Style="{StaticResource ChromeButton}" Click="BtnMinimize_Click"/>
                            <Button Content="[X]" Style="{StaticResource ChromeButton}"
                                    Foreground="#FF6666" Margin="4,0,0,0" Click="BtnClose_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Section header -->
                <StackPanel Grid.Row="1" Margin="20,16,20,12">
                    <TextBlock Text="{loc:Loc SCORE_TITLE}"
                               FontFamily="Courier New" FontSize="18" FontWeight="Bold"
                               Foreground="#00FF41"/>
                    <Border Background="#00FF41" Height="1" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Stats summary row -->
                <Grid Grid.Row="2" Margin="20,0,20,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" BorderBrush="#007A1F" BorderThickness="1" Margin="0,0,6,0" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc SCORE_TOTAL}" FontFamily="Courier New" FontSize="10" Foreground="#00AA30"/>
                            <TextBlock x:Name="TxtTotal" Text="0" FontFamily="Courier New" FontSize="26" FontWeight="Bold" Foreground="#00FF41"/>
                            <TextBlock Text="{loc:Loc SCORE_GAMES}" FontFamily="Courier New" FontSize="10" Foreground="#007A1F"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" BorderBrush="#007A1F" BorderThickness="1" Margin="3,0,3,0" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc SCORE_WON_STAT}" FontFamily="Courier New" FontSize="10" Foreground="#00AA30"/>
                            <TextBlock x:Name="TxtWon" Text="0" FontFamily="Courier New" FontSize="26" FontWeight="Bold" Foreground="#00FF41"/>
                            <TextBlock Text="{loc:Loc SCORE_VICTORIES}" FontFamily="Courier New" FontSize="10" Foreground="#007A1F"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" BorderBrush="#007A1F" BorderThickness="1" Margin="3,0,3,0" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc SCORE_LOST_STAT}" FontFamily="Courier New" FontSize="10" Foreground="#00AA30"/>
                            <TextBlock x:Name="TxtLost" Text="0" FontFamily="Courier New" FontSize="26" FontWeight="Bold" Foreground="#FF6666"/>
                            <TextBlock Text="{loc:Loc SCORE_DEFEATS}" FontFamily="Courier New" FontSize="10" Foreground="#7A3030"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" BorderBrush="#007A1F" BorderThickness="1" Margin="6,0,0,0" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc SCORE_POINTS_STAT}" FontFamily="Courier New" FontSize="10" Foreground="#00AA30"/>
                            <TextBlock x:Name="TxtPoints" Text="0" FontFamily="Courier New" FontSize="26" FontWeight="Bold" Foreground="#00FF41"/>
                            <TextBlock Text="{loc:Loc SCORE_GLOBAL}" FontFamily="Courier New" FontSize="10" Foreground="#007A1F"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- DataGrid -->
                <DataGrid x:Name="ScoreGrid" Grid.Row="3" Margin="20,0,20,0"
                          Background="#0C0C0C" Foreground="#00FF41"
                          BorderBrush="#007A1F" BorderThickness="1"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1A2A1A"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          RowBackground="#0C0C0C" AlternatingRowBackground="#0A150A"
                          HeadersVisibility="Column" FontFamily="Courier New" FontSize="13">
                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#003B10"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#002A0C"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#00FF41"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#00FF41"/>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#001A00"/>
                            <Setter Property="Foreground" Value="#00AA30"/>
                            <Setter Property="BorderBrush" Value="#007A1F"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            <Setter Property="FontFamily" Value="Courier New"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="12,8"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="#00FF41"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#001A08"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="12,7" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{loc:Loc GRID_WORD}" Binding="{Binding Palabra}" Width="*"/>
                        <DataGridTextColumn Header="{loc:Loc GRID_RIVAL}" Binding="{Binding Rival}" Width="*"/>
                        <DataGridTextColumn Header="{loc:Loc GRID_RESULT}" Binding="{Binding Resultado}" Width="110"/>
                        <DataGridTextColumn Header="{loc:Loc GRID_POINTS}" Binding="{Binding Puntos}" Width="80"/>
                        <DataGridTextColumn Header="{loc:Loc GRID_DATE}" Binding="{Binding Fecha}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Bottom button -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                            Margin="20,14,20,14">
                    <Button Content="{loc:Loc BACK_TO_MENU_BUTTON}"
                            Style="{StaticResource RetroButton}"
                            Height="36" Padding="16,0"
                            Click="BtnBack_Click"/>
                </StackPanel>

                <!-- Footer -->
                <Border Grid.Row="5" Background="#001200" BorderBrush="#00FF41" BorderThickness="0,1,0,0">
                    <TextBlock Text="{loc:Loc FOOTER_SCORE}"
                               FontFamily="Courier New" FontSize="10" Foreground="#007A1F"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Rectangle IsHitTestVisible="False" Panel.ZIndex="100">
            <Rectangle.Fill>
                <DrawingBrush TileMode="Tile" Viewport="0,0,1,4" ViewportUnits="Absolute"
                              Viewbox="0,0,1,4" ViewboxUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing Brush="#18000000">
                            <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,1,2"/></GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
</Window>

